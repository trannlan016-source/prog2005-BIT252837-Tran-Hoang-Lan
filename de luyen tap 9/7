class Person:
    def __init__(self, name, age):
        self.name = name
        self.age = age

    @classmethod
    def from_string(cls, data_str):
        name, age = data_str.split("-")
        return cls(name, int(age))

    def display(self):
        print(f"Name: {self.name}, Age: {self.age}")

p = Person.from_string("Lan-18")

p.display()
