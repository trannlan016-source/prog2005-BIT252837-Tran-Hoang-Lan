def binary_search(arr , target):
    low = 0
    high = len(arr) - 1
    target_len = len(target)

    while low <= high:
        mid = (low + high) // 2
        current_len = len(arr[mid])
        if current_len == target_len:
            if arr[mid] == target:
                return mid
            else:
                 break
        elif current_len < target_len:
            high = mid - 1
        else:
            low = mid + 1
    return -1
arr = ["chuoi rat dai","chuoi dai",'chuoi vua',"chuoi ngan","it"]
search_item = input("nhap chuoi can tim")
result = binary_search(arr,search_item)

if result != -1:
    print(f"tim thay chuoi '{search_item}' tai vi tri index {result} (vi tri thu {result + 1})")
else:
