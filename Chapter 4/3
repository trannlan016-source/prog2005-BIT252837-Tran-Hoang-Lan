def kiem_tra_key(tu_dien, key_can_tim):
    if key_can_tim in tu_dien:
        return True
    else:
        return False

my_dict = {"Ten": "Lan", "Tuoi": 18, "Lop": "cslt"}

key = "Tuoi"
if kiem_tra_key(my_dict, key):
    print(f"Key '{key}' ton tai trong dictionary.")
else:
    print(f"Key '{key}' khong ton tai.")

key_ao = "Diem"
print(f"Ket qua tim '{key_ao}':", kiem_tra_key(my_dict, key_ao))
