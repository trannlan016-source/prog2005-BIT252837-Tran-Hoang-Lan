class Product:
    def __init__(self, price):
        self.price = price 

    @property
    def price(self):
        return self._price

    @price.setter
    def price(self, value):
        if value > 0:
            self._price = value
        else:
            print("Loi: Gia phai lon hon 0!")
            self._price = 1  

    def __str__(self):
        return f"San pham co gia: {self._price}"

p1 = Product(100)
print(p1)

p2 = Product(-50)
print(p2)
