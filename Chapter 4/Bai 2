def tinh_diem_trung_binh(ds_sinh_vien):
    if len(ds_sinh_vien) == 0:
        return 0

    tong_diem = sum(ds_sinh_vien.values())
    so_luong = len(ds_sinh_vien)
    return tong_diem / so_luong

sinh_vien = {
    "tuyen": 8,
    "duc": 7,
    "duong": 9
}

dtb = tinh_diem_trung_binh(sinh_vien)
print("Diem trung binh la:", dtb)
