class Student:
    def __init__(self, ten, diem):
        self.ten = ten
    
        if 0 <= diem <= 10:
            self.diem = diem
        else:
            self.diem = 0
            print("Diem khong hop le, da dat ve 0")


sv_loi = Student("Chi", 15) 
print(f"Diem cua {sv_loi.ten} la: {sv_loi.diem}")
